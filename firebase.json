{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "alba-work",
          "appId": "1:319960355608:android:acddd0bec19a47f48c846d",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "alba-work",
          "configurations": {
            "android": "1:319960355608:android:acddd0bec19a47f48c846d"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "landing",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/.well-known/**",
        "headers": [
          { "key": "Content-Type", "value": "application/json" }
        ]
      },
      {
        "source": "**/*.@(css|js|svg|webp|png)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/jobs/**",
        "destination": "/index.html"
      },
      {
        "source": "/referral/**",
        "destination": "/index.html"
      },
      {
        "source": "/line-callback",
        "destination": "/index.html"
      },
      {
        "source": "/auth/line",
        "function": "lineAuthStart"
      },
      {
        "source": "/auth/line/callback",
        "function": "lineAuthCallback"
      },
      {
        "source": "/auth/line/exchange",
        "function": "lineAuthExchange"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
