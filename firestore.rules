rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function isString(v) { return v is string; }
    function isTimestamp(v) { return v is timestamp; }
    function isInt(v) { return v is int; }

    function isAdminUid() {
      return signedIn()
        && exists(/databases/$(database)/documents/config/admins)
        && (
          uid() in get(/databases/$(database)/documents/config/admins).data.adminUids
          || request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails
        );
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdminUid();
    }

    match /jobs/{jobId} {
      allow read: if true;

      allow create: if signedIn()
        && (isAdminUid() || (request.resource.data.ownerId == uid()))
        && isString(request.resource.data.title)
        && request.resource.data.title.size() <= 100
        && isString(request.resource.data.location)
        && request.resource.data.location.size() <= 200
        && isString(request.resource.data.price)
        && isString(request.resource.data.date)
        && (!("description" in request.resource.data.keys()) || request.resource.data.description.size() <= 5000)
        && (!("notes" in request.resource.data.keys()) || request.resource.data.notes.size() <= 2000);

      allow update: if signedIn()
        && (isAdminUid() || (resource.data.ownerId == uid()))
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "title","location","price","date",
          "description","notes",
          "prefecture",
          "workDateKey","workMonthKey",
          "updatedAt",
          "projectName",
          "latitude","longitude"
        ])
        && (!("title" in request.resource.data.diff(resource.data).changedKeys()) || request.resource.data.title.size() <= 100)
        && (!("location" in request.resource.data.diff(resource.data).changedKeys()) || request.resource.data.location.size() <= 200)
        && (!("description" in request.resource.data.diff(resource.data).changedKeys()) || request.resource.data.description.size() <= 5000)
        && (!("notes" in request.resource.data.diff(resource.data).changedKeys()) || request.resource.data.notes.size() <= 2000);

      allow delete: if signedIn()
        && (isAdminUid() || (resource.data.ownerId == uid()));
    }

    function isAppPartyData(appData) {
      return signedIn()
        && (appData.applicantUid == uid() || appData.adminUid == uid());
    }

    match /applications/{appId} {
      allow read: if signedIn()
        && (isAdminUid() || isAppPartyData(resource.data));

      allow create: if signedIn()
        && request.resource.data.applicantUid == uid()
        && isString(request.resource.data.adminUid)
        && isString(request.resource.data.jobId)
        && isString(request.resource.data.status)
        && request.resource.data.status == "applied"
        && isString(request.resource.data.projectNameSnapshot)
        && request.resource.data.projectNameSnapshot.size() <= 200;

      allow update: if isAppPartyData(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status","updatedAt",
          "projectNameSnapshot",
          "jobTitleSnapshot","jobLocationSnapshot","jobPriceSnapshot","jobDateSnapshot",
          "checkInAt","checkOutAt","checkInStatus",
          "checkInMethod","checkInLatitude","checkInLongitude","checkInDistance",
          "checkOutLatitude","checkOutLongitude","checkOutDistance",
          "qrVerified","gpsVerified"
        ]);

      allow delete: if false;
    }

    match /profiles/{profileUid} {
      allow read: if signedIn() && (uid() == profileUid || isAdminUid());
      allow create: if signedIn() && uid() == profileUid;

      allow update: if signedIn()
        && uid() == profileUid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "displayName","name","email","photoUrl","phone",
          "fcmToken","updatedAt",
          "familyName","givenName","familyNameKana","givenNameKana",
          "birthDate","gender","postalCode","address",
          "introduction","experienceYears","qualifications",
          "termsAcceptedAt","privacyAcceptedAt"
        ])
        && request.resource.data.displayName.size() <= 50
        && (!("introduction" in request.resource.data.diff(resource.data).changedKeys())
            || request.resource.data.introduction.size() <= 2000);

      allow delete: if false;
    }

    // --- contacts (お問い合わせ) ---
    match /contacts/{contactId} {
      allow read: if signedIn() && (isAdminUid() || resource.data.uid == uid());
      allow create: if signedIn()
        && request.resource.data.uid == uid()
        && isString(request.resource.data.subject)
        && request.resource.data.subject.size() <= 200
        && isString(request.resource.data.body)
        && request.resource.data.body.size() <= 5000
        && isString(request.resource.data.category);
      allow update, delete: if false;
    }

    // --- notifications (通知) ---
    match /notifications/{notifId} {
      allow read: if signedIn() && resource.data.targetUid == uid();
      allow create: if signedIn()
        && (request.resource.data.targetUid == uid() || isAdminUid())
        && isString(request.resource.data.title)
        && request.resource.data.title.size() <= 200
        && isString(request.resource.data.body)
        && request.resource.data.body.size() <= 5000;
      allow update: if signedIn() && resource.data.targetUid == uid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["read"]);
      allow delete: if false;
    }

    // --- stats (リアルタイムカウンタ — Cloud Functions のみ書き込み) ---
    match /stats/{docId} {
      allow read: if signedIn() && isAdminUid();
      allow write: if false;
    }

    // --- KPI (Cloud Functions のみ書き込み、admin のみ読み取り) ---
    match /kpi_daily/{dateKey} {
      allow read: if signedIn() && isAdminUid();
      allow write: if false;
    }
    match /kpi_monthly/{monthKey} {
      allow read: if signedIn() && isAdminUid();
      allow write: if false;
    }

    // --- favorites (お気に入り) ---
    match /favorites/{favUid} {
      allow read, write: if signedIn() && favUid == uid();
    }

    function appDoc(appId) {
      return get(/databases/$(database)/documents/applications/$(appId)).data;
    }

    function chatPartyByApp(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/applications/$(chatId))
        && (appDoc(chatId).applicantUid == uid() || appDoc(chatId).adminUid == uid());
    }

    match /chats/{chatId} {
      allow read: if chatPartyByApp(chatId);

      allow create: if chatPartyByApp(chatId)
        && request.resource.data.keys().hasOnly([
          "applicationId",
          "applicantUid",
          "adminUid",
          "jobId",
          "titleSnapshot",
          "createdAt",
          "updatedAt"
        ])
        && isString(request.resource.data.applicationId)
        && request.resource.data.applicationId == chatId
        && isString(request.resource.data.applicantUid)
        && isString(request.resource.data.adminUid)
        && isString(request.resource.data.jobId)
        && isString(request.resource.data.titleSnapshot)
        && request.resource.data.applicantUid == appDoc(chatId).applicantUid
        && request.resource.data.adminUid == appDoc(chatId).adminUid
        && request.resource.data.jobId == appDoc(chatId).jobId;

      allow update: if chatPartyByApp(chatId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "lastMessageText","lastMessageAt","lastMessageSenderUid",
          "unreadCountApplicant","unreadCountAdmin",
          "updatedAt","titleSnapshot"
        ]);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if chatPartyByApp(chatId);

        allow create: if chatPartyByApp(chatId)
          && request.resource.data.senderUid == uid()
          && request.resource.data.keys().hasOnly(["senderUid","text","createdAt"])
          && isString(request.resource.data.text)
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 5000;

        allow update, delete: if false;
      }
    }

    // --- ratings ---
    match /ratings/{ratingId} {
      allow read: if signedIn();

      allow create: if isAdminUid()
        && isString(request.resource.data.applicationId)
        && isString(request.resource.data.jobId)
        && isString(request.resource.data.targetUid)
        && isString(request.resource.data.raterUid)
        && request.resource.data.raterUid == uid()
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;

      allow update, delete: if false;
    }

    // --- payments ---
    match /payments/{paymentId} {
      allow read: if signedIn() && (
        isAdminUid()
        || resource.data.workerUid == uid()
        || resource.data.adminUid == uid()
      );
      allow create: if false;
      allow update, delete: if false;
    }

    // --- shifts (sub-collection of jobs) ---
    match /jobs/{jobId}/shifts/{shiftId} {
      allow read: if signedIn();
      allow create: if isAdminUid()
        && isString(request.resource.data.qrCode)
        && isString(request.resource.data.date);
      allow update, delete: if isAdminUid();
    }

    match /earnings/{earningId} {
      allow read: if signedIn() && (
        isAdminUid() || (resource.data.uid == uid())
      );

      allow create: if isAdminUid()
        && isString(request.resource.data.uid)
        && isString(request.resource.data.applicationId)
        && isString(request.resource.data.projectNameSnapshot)
        && request.resource.data.projectNameSnapshot.size() <= 200
        && isInt(request.resource.data.amount)
        && isTimestamp(request.resource.data.payoutConfirmedAt);

      allow update: if isAdminUid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "uid","applicationId","projectNameSnapshot",
          "amount","payoutConfirmedAt","jobId","updatedAt"
        ]);

      allow delete: if isAdminUid();
    }

    // --- 分散カウンタ (Cloud Functions のみ書き込み) ---
    match /counters/{counterId} {
      allow read: if signedIn() && isAdminUid();
      allow write: if false;

      match /shards/{shardId} {
        allow read: if signedIn() && isAdminUid();
        allow write: if false;
      }
    }

    // --- 監査ログ (Cloud Functions のみ書き込み、admin のみ読み取り) ---
    match /audit_logs/{logId} {
      allow read: if signedIn() && isAdminUid();
      allow write: if false;
    }

    // --- LINE認証 (Cloud Functions のみ管理 — クライアント禁止) ---
    match /line_auth_states/{stateId} {
      allow read, write: if false;
    }
    match /line_auth_tokens/{tokenId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
